# SQLite database file path. Use :memory: for tests.
DATABASE_PATH=data/timeoff.sqlite

# HCM API connection (required)
HCM_BASE_URL=http://localhost:3001
HCM_API_KEY=your-hcm-api-key-here

# HCM HTTP call timeout in milliseconds
HCM_TIMEOUT_MS=3000

# Max PENDING_HCM retry attempts before marking a request FAILED
HCM_RETRY_ATTEMPTS=5

# Max optimistic-lock retries for balance mutations (default: 3)
BALANCE_LOCK_RETRIES=3

# Cron schedule for the HCM retry / balance-sync background job
SYNC_CRON=0 1 * * *

# Minimum age (minutes) before a cached balance is refreshed from HCM
BALANCE_REFRESH_THRESHOLD_MINUTES=15

# HTTP port (default: 3000)
# PORT=3000
